cat > .env.example << 'EOF'
# ============================================
# Frontend Environment Variables (.env.example)
# ============================================
# Copy this file to .env.local and fill in values
# React variables MUST start with REACT_APP_

# ============================================
# API Configuration
# ============================================
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000

# ============================================
# Stripe Public Key (Safe to expose)
# ============================================
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_your_public_stripe_key

# ============================================
# Google Maps API (Safe to expose with restrictions)
# ============================================
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# Application Config
# ============================================
REACT_APP_ENV=development
REACT_APP_APP_NAME=Digital Freight Booking
REACT_APP_VERSION=1.0.0

# ============================================
# Feature Flags (Optional)
# ============================================
REACT_APP_ENABLE_DEMO_MODE=true
REACT_APP_ENABLE_ANALYTICS=false

# ============================================
# Analytics (Optional)
# ============================================
REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
REACT_APP_SENTRY_DSN=
EOF